{
  "name": "planflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:ota": "vue-tsc -b && vite build && node scripts/generate-ota.mjs",
    "ota:serve": "node scripts/ota-server.mjs",
    "deploy:ota": "npm run build:ota && wrangler pages deploy dist --project-name planflow",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@element-plus/icons-vue": "^2.3.2",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "playwright-core": "1.60.0",
    "sass": "^1.101.0",
    "uuid": "^14.0.1",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^24.13.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.107.0"
  }
}
